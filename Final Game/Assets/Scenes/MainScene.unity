  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: First Aid
    requestTags:
    - Protection
    - Comfort
    - Blood
    consequenceLines:
    - "\"There\u2019s nothing to help us if something goes wrong now. That thought
      stays in my head longer than it should. We feel farther apart.\" "
    - "\"It feels like I took away our safety. If someone gets hurt, I don\u2019t
      know what we\u2019ll do. We feel farther apart.\""
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - This is what we use when someone gets hurt. It's usually for Dad.
    - "Dad always knows where this is. He says it\u2019s important. "
