--- !u!114 &1798744013
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1798744012}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Candle
    requestTags:
    - Warmth
    - Comfort
    - Sight
    consequenceLines:
    - " \u201CJane's room feels darker now, even though it\u2019s still daytime.
      She keeps looking at where it used to sit, like it might come back. I don\u2019t
      think she feels as safe anymore. We feel farther apart.\u201D\r"
    - " \u201CJane pulls her sleeves over her hands and curls up tighter than before.
      The room feels colder, like something small but important is missing. I think
      I made it harder for her to feel okay. We feel farther apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - We keeps it close when it gets dark. The light makes the family feel a little
      safer.
    - "It doesn\u2019t really warm the family, but it makes it feel less cold somehow."
    - "When it\u2019s on, the family stops shaking as much."
