--- !u!114 &764884309
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 764884307}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Peanut Butter
    requestTags:
    - Comfort
    - Hunger
    consequenceLines:
    - "\"The hunger doesn\u2019t go away this time. It just sits there, deeper than
      before. Like it\u2019s waiting for more. I feel worse.\""
    - "\"I feel emptier after. In my stomach. Like something inside me expected more
      and didn\u2019t get it. I feel worse.\""
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - I like how heavy it feels when I eat it. Like something is finally filling
      me up.
    - "I don\u2019t need anything else with it. Just this is enough."
