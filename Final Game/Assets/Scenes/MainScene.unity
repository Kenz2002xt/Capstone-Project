--- !u!114 &1139385782
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1139385780}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Book
    requestTags:
    - Information
    - Escape
    - Memory
    - Silence
    - Distraction
    consequenceLines:
    - "\u201CThere\u2019s nothing to focus on now. Nothing to pull my mind somewhere
      else. I wish I remembered that story. I feel worse.\u201D"
    - "\u201CI think it helped more than I realized. Now there\u2019s nothing to
      distract from everything else. It feels harder to sit in here. I feel worse.\u201D"
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "I read it when I don\u2019t want to think about what\u2019s happening."
    - "The pages feel safe, like nothing bad can reach me while I\u2019m inside the
      story."
