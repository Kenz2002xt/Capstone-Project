MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1589735423}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Pillow
    requestTags:
    - Warmth
    - Comfort
    - Escape
    consequenceLines:
    - " \u201CJane doesn\u2019t look comfortable anymore. She keeps shifting, like
      she can\u2019t settle. I think I took the one thing that helped her rest. We
      feel farther apart.\u201D"
    - "\u201CJane hugs herself instead now. The room feels less soft, less safe somehow.
      I didn\u2019t think something that small mattered this much. We feel farther
      apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - Jane hides her face in it like she can go somewhere else.
    - "My sister hugs it when she\u2019s cold."
