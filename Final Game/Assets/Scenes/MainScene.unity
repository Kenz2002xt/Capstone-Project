--- !u!114 &1001796483
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 890450405}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Picture
    requestTags:
    - Comfort
    - Memory
    consequenceLines:
    - "\u201CI keep looking at the wall where it used to be. It feels wrong without
      it there. Like the family forgot something. We feel farther apart.\u201D"
    - " \u201CI didn\u2019t think it mattered this much. But now it feels like something
      important is missing from all of us. Like we lost a piece of what we were.
      We feel farther apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "We laugh about it sometimes. It\u2019s one of the few things that still feels
      normal. "
    - "It reminds me of when we weren\u2019t so serious all the time."
