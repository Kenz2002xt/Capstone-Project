--- !u!114 &1335057000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1335056998}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Television
    requestTags:
    - Distraction
    - Noise
    consequenceLines:
    - "\"The silence feels worse now. There\u2019s nothing to fill it, nothing to
      distract me. I hear things I didn\u2019t before. I feel worse.\""
    - "\"The room feels still. Too still. Without the noise, everything feels closer,
      like it\u2019s pressing in on me. I feel worse.\""
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - 'It fills the room with sound. Even when no one is watching with me, it makes
      me laugh. '
    - "The flickering light makes everything feel different, like I\u2019m somewhere
      else. "
