--- !u!114 &657149259
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 657149257}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Tape
    requestTags:
    - Protection
    consequenceLines:
    - "\"Small things start breaking more easily. Things that used to hold don\u2019t
      anymore. The house feels more fragile. The house feels weaker.\""
    - "\"It\u2019s harder to fix anything now. Once something breaks, it stays broken.
      I don\u2019t think we can hold things together like before. The house feels
      weaker.\""
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "We use this to fix the house. It\u2019s not perfect, but it works."
    - It covers the holes in the wall. Keeps the birds out.
