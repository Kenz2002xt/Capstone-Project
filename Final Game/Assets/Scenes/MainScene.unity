--- !u!114 &2054218337
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2054218335}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Wrench
    requestTags:
    - Protection
    consequenceLines:
    - "\"The pipes groan louder tonight. Water drips somewhere deep in the walls,
      and it doesn\u2019t stop. The house feels like it\u2019s slowly coming undone.
      The house feels weaker.\""
    - "\"Something in the pipes shifts. The air feels colder, like the house isn\u2019t
      protecting us the same way anymore. I don\u2019t think it can hold together
      much longer. The house feels weaker.\""
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "It\u2019s heavy my hands. Dad uses it when something in the house breaks."
    - 'The metal smells like the sink. I think this is what keeps the pipes from
      leaking. '
    - It looks important, like something the house needs to stay okay.
