  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Knife
    requestTags:
    - Protection
    - Control
    - Fear
    consequenceLines: []
    statTag: Home
    value: 10
    sacrificeWeight: 0
    descriptions:
    - "Dad says I\u2019m not allowed to touch this unless he\u2019s watching."
    - It feels heavier than it looks when I pick it up.
    - "I don\u2019t really like how sharp it is\u2026 like it could mess things up
      fast."
    - "It stays in the same spot every time, like it\u2019s not supposed to move."
    - Sometimes I think about what would happen if I dropped it.
