--- !u!114 &1658052791
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1658052790}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Mug
    requestTags:
    - Warmth
    - Comfort
    - Silence
    consequenceLines:
    - "\u201CI reach for it without thinking, then remember it\u2019s not there.
      It was something small, but it made things easier. Now the house feels just
      a little less comforting. I feel worse.\u201D"
    - " \u201CMy hands feel colder without it. It\u2019s weird how something so simple
      mattered this much. I think the house feels it too. I feel worse.\u201D"
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "I hold it even when there\u2019s nothing in it."
    - It makes my hands feel warmer for a little bit.
    - "It\u2019s reminds me of quiet. Nothing about it feels bad."
