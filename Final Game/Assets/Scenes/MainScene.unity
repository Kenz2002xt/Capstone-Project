  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Toilet Paper
    requestTags:
    - Comfort
    consequenceLines:
    - "\"Things feel dirtier now. Not just the bathroom but everything. Like we can\u2019t
      take care of ourselves properly anymore. We feel farther apart.\""
    - "\"It\u2019s harder to feel comfortable. Little things start to bother me more.
      We don't feel normal. We feel farther apart.\""
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "It\u2019s simple, but we always need it. Mom says not to waste it. "
    - It feels small, but we notice when it starts to run out.
