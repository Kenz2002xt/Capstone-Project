--- !u!114 &1240507683
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1240507682}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Binoculars
    requestTags:
    - Sight
    - Information
    consequenceLines:
    - "\"It\u2019s harder to focus now. The world feels blurred at the edges, like
      I\u2019m missing something important. I don\u2019t like not seeing clearly.
      I feel worse.\""
    - "\"I keep thinking something is moving outside, but I can\u2019t see where.
      It feels like I\u2019ve lost my sense of what\u2019s real and what\u2019s not.
      I feel worse.\" "
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - I can see far away with these. Things look closer than they should.
    - 'I used these to look outside before. It felt safer seeing things first. '
    - If I hold them up, I can watch without being seen.
