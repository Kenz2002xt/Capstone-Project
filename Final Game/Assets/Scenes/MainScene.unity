--- !u!114 &1247282047
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1247282046}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Pot
    requestTags:
    - Hunger
    - Warmth
    - Comfort
    consequenceLines:
    - "\u201CThe kitchen doesn\u2019t feel like a place we can survive in anymore.
      It\u2019s harder to imagine anything warm coming from here. I think I took
      away something that kept us going. The house feels weaker.\u201D"
    - "\u201CThere\u2019s a hollow feeling in the room now. Like something meant
      to take care of us is just\u2026 gone. It makes the whole house feel less prepared.
      The house feels weaker.\u201D"
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - 'It sits on the stove and fills the house with warmth when something is cooking. '
    - The steam makes the kitchen feel alive again. Like the house is still taking
      care of us.
    - "I like when it\u2019s full. It makes the house feel less empty. "
