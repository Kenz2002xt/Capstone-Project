--- !u!114 &1664695502
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1664695500}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Bottle
    requestTags:
    - Escape
    - Distraction
    - Comfort
    consequenceLines:
    - "\u201CThe room feels more tense now. Like there\u2019s no easy way to make
      things quieter anymore. I think I took away something they relied on. We feel
      farther apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "Dad doesn\u2019t really say much when it\u2019s out. He gets distracted."
    - "I\u2019ve seen it help Mom and Dad\u2026 for a little while."
