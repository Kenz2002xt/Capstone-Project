--- !u!114 &762272651
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 762272649}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Bunny Toy
    requestTags:
    - Comfort
    - Memory
    consequenceLines:
    - "\"She looks for it before bed. When she can\u2019t find it, she just lies
      there quietly. It feels like I took something she needed to feel okay. We feel
      farther apart.\""
    - '"The room feels colder somehow. Not in the air, but in the way she curls up
      smaller now. I think I took more than just a toy. We feel farther apart."'
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "Jane sleeps with this every night. It\u2019s always tucked under her arm."
    - The fur is worn down, but my sister still holds it like it matters.
    - 'I think it helps Jane feel safe when things get loud. '
