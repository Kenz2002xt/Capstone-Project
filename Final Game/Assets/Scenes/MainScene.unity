--- !u!114 &220101761
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 210617342}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Radio
    requestTags:
    - Noise
    - Escape
    - Distraction
    - Comfort
    consequenceLines:
    - "\u201CThe room is too quiet now. Every little sound feels louder, sharper.
      I think she notices it too, even if she doesn\u2019t say anything. We feel
      farther apart.\u201D\r"
    - "\u201CShe doesn\u2019t turn anything on this time. She just sits there, listening
      to nothing. It feels like I took away her way of escaping for a while. We feel
      farther apart.\u201D\r"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "My sister turns it on just so it\u2019s not so quiet."
    - The noise makes it easier for my family not to think about things.
    - "Even when it\u2019s just static, my sister won\u2019t turn it off."
