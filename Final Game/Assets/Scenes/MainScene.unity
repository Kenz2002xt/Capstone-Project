--- !u!114 &1736785641
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1736785640}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Medication
    requestTags:
    - Comfort
    - Escape
    - Distraction
    consequenceLines:
    - "\"I feel weaker after this. Like something inside me isn\u2019t working the
      way it should anymore. It\u2019s harder to ignore it. I feel worse.\""
    - '"My body feels off. Not sick exactly, just wrong. Like something important
      is missing now. I feel worse."'
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "This one is different. It\u2019s not just for my pain\u2026it\u2019s for something
      serious."
    - "Mom keeps it in a safe place. She says it\u2019s important for me stay okay."
