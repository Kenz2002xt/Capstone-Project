--- !u!114 &242465604
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 180812965}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Broom
    requestTags:
    - Comfort
    - Silence
    consequenceLines:
    - "\"The dirt stays now. It gathers in corners and doesn\u2019t go away. The
      house feels harder to take care of. The house feels weaker.\""
    - "\"Things feel messier, even when they aren\u2019t. Like something is building
      up that I can\u2019t fix anymore. The house feels weaker.\""
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "I sweep the floor and the house feels quieter after. Like I\u2019m fixing
      something small."
    - The dust gathers in the corners where the walls meet.
    - "It makes the house feel a little more taken care of, even if everything else
      isn\u2019t."
