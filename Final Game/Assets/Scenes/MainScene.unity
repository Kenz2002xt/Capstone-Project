--- !u!114 &1818372177
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1818372176}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Sticky Note
    requestTags:
    - Information
    - Memory
    consequenceLines:
    - "\u201CI try to remember what it said, but I\u2019m not sure anymore. It was
      something important, I think. Now it\u2019s just gone. We feel farther apart.\u201D"
    - " \u201CIt was small, but it helped keep things straight. Without it, everything
      feels a little more uncertain. Like something slipped out of place. We feel
      farther apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "Someone wrote this so they wouldn\u2019t forget."
    - 'The writing looks rushed, like it was important for us to remember. '
