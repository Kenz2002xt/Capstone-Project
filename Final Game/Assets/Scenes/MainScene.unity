--- !u!114 &1074539132
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1074539130}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Flashlight
    requestTags:
    - Sight
    - Protection
    consequenceLines:
    - "\"The dark feels thicker tonight. It\u2019s harder to tell what\u2019s there
      and what isn\u2019t. I don\u2019t think I can trust my eyes in this house anymore.
      The house feels weaker.\""
    - "\"I keep looking into corners, but nothing stays clear for long. It feels
      like something is just outside where I can see. I don\u2019t like not knowing
      what\u2019s watching the house. The house feels weaker.\""
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - 'The light slides across the walls and makes everything feel less hidden. '
    - "The corners of the house feel different in the dark. This helps us see what\u2019s
      still there and what isn\u2019t. "
