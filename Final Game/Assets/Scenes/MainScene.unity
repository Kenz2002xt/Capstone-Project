--- !u!114 &1179452722
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1179452721}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Axe
    requestTags:
    - Protection
    - Blood
    consequenceLines:
    - "\"The house feels less safe without it. Not because something is coming\u2026but
      because now we have nothing to fight it with. The house feels weaker.\""
    - "\"I keep thinking about what it\u2019s capable of. And now that it\u2019s
      gone, I don\u2019t know if that\u2019s better or worse. Something feels unprotected
      either way. The house feels weaker.\""
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "It\u2019s for chopping wood so the house stays warm. It helps keep the cold
      out of the walls."
    - "I don\u2019t like holding it, but I know it protects the house when things
      get bad."
    - "It\u2019s heavy and sharp. It feels like something meant to keep the house
      safe, no matter what. "
