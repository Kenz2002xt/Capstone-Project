--- !u!114 &1845950340
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 917646898}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Trash
    requestTags:
    - Distraction
    - Silence
    - Hunger
    consequenceLines:
    - "\u201CThere\u2019s nowhere to put things anymore. The mess feels more noticeable
      now. Like things are starting to pile up in ways we can\u2019t ignore. The
      house feels weaker.\u201D"
    - " \u201CIt wasn\u2019t important until it was gone. Now everything just stays
      where it is. The house feels a little less put together. The house feels weaker.\u201D"
    statTag: Home
    value: 14
    sacrificeWeight: 0
    descriptions:
    - Stuff goes in here so nobody in our house has to look at it.
    - Mom usually empties it without saying anything. Our home feels cleaner.
    - "It\u2019s easier to throw things away in this house than deal with them."
