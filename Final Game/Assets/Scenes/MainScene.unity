  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Candle
    requestTags:
    - Warmth
    - Routine
    - Calm
    - Silence
    consequenceLines: []
    statTag: Self
    value: 10
    sacrificeWeight: 0
    descriptions:
    - They said the lights might go out...this will help.
    - It just sits there on our desk, never lit.
    - I think I bought it because it smelled nice at the store.
    - "It makes the room feel quieter even when nothing\u2019s happening."
