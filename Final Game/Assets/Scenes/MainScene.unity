  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Letter
    requestTags:
    - Information
    - Understanding
    - Communication
    consequenceLines: []
    statTag: Family
    value: 10
    sacrificeWeight: 0
    descriptions:
    - My sisters been writing more.
    - I can see her handwriting through the paper a little.
    - "It\u2019s been sitting here for a while, untouched."
    - "I don\u2019t know if she ever meant to send this."
    - "I feel like I shouldn\u2019t look at it, even if it\u2019s mine to see."
