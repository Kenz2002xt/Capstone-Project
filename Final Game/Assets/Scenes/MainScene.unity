--- !u!114 &912235126
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 912235123}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Flare
    requestTags:
    - Protection
    - Sight
    - Noise
    consequenceLines:
    - "\"I keep thinking about how loud it was. It\u2019s too quiet now. Like I lost
      something that could fight back. I don\u2019t feel as safe without it. I feel
      worse.\""
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - "It\u2019s loud when I shoot it. Loud enough to scare anything away"
    - The red light burns bright. It feels like something I could use to call for
      help.
