  m_IsActive: 1
--- !u!114 &2084705520
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2084705519}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 09732b5a3c7488c4485bc54603714156, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dayOneInstructionPanel: {fileID: 1300552750}
  dayOneInstructionText: {fileID: 293064873}
  requestText: {fileID: 1691593750}
  dialogueText: {fileID: 901125800}
  dayText: {fileID: 688725734}
  endText: {fileID: 1382300497}
  optionsPanel: {fileID: 336682106}
  journal: {fileID: 116313004}
  homeSlider: {fileID: 386873557}
  selfSlider: {fileID: 845589879}
  familySlider: {fileID: 2114344382}
  parentsButton: {fileID: 1741570046}
  sisterButton: {fileID: 1460239452}
  bathroomButton: {fileID: 465999257}
  kitchenButton: {fileID: 1299664311}
  windowButton: {fileID: 1846222248}
  porchButton: {fileID: 706163599}
  explorationSystem: {fileID: 402014206}
  kitchenRoomManager: {fileID: 531234552}
  sisterRoomManager: {fileID: 227505085}
  parentRoomManager: {fileID: 1560944311}
  bathroomManager: {fileID: 396362885}
  narrativeManager: {fileID: 2096678380}
  parentMorningDialogues:
  - firstLine: "\u201CIt\u2019s colder inside the house today. I checked the windows
      twice, and they\u2019re sealed tight, but the cold still gets in somehow. That
      shouldn\u2019t be happening.\u201D\r"
    firstChoiceA: "\u201CI feel it too.\u201D"
    firstChoiceB: "\u201CMaybe it\u2019ll pass.\u201D "
    secondLine: "\u201CWe just need to keep things steady. If the house holds together,
      then we\u2019ll be fine. That\u2019s what matters most right now.\u201D\r"
    secondChoiceA: "\u201CI\u2019ll help keep it together.\u201D "
    secondChoiceB: "\u201CWhat if it doesn\u2019t hold?\u201D "
    finalLine: "\u201CJust stay close today. Don\u2019t wander too far from the rooms\".
      They seem tired.\r"
  - firstLine: "\u201CThe windows are frosting from the inside now. I wiped them
      clean, but it came back almost immediately. That damn frost is pushing its
      way in.\u201D\r\r"
    firstChoiceA: "\u201CThat\u2019s not normal.\u201D "
    firstChoiceB: "\u201CWe can cover them.\u201D "
    secondLine: "\u201CNo, something feels off. The foundation. The house is taking
      all this pressure for us.\u201D\r"
    secondChoiceA: "\u201CIt\u2019s protecting us.\u201D"
    secondChoiceB: "\u201CIt won\u2019t last.\u201D "
    finalLine: "\u201CWe just need to keep it standing\". Mom and Dad exchange a
      look you don\u2019t understand.\r"
  - firstLine: "\u201CWe\u2019ve had hard winters before.\u201D\r\n"
    firstChoiceA: "\u201CThis isn\u2019t the same.\u201D "
    firstChoiceB: "\u201CYeah\u2026 we\u2019ll manage.\u201D "
    secondLine: "\u201CIt takes something from you.\u201D\r\r\n"
    secondChoiceA: " \u201CThe cold?\u201D "
    secondChoiceB: "\u201CWhat do you mean?\u201D  "
    finalLine: 'The room feels quieter than it should.

'
  - firstLine: "\u201CThe back room lost all its warmth overnight. Not faded\u2026
      gone. Like something took it instead of it just disappearing.\u201D\r"
    firstChoiceA: "\u201CWe should stay out of there.\u201D "
    firstChoiceB: "\u201CCan we fix it?\u201D "
    secondLine: "\u201CDon\u2019t take from the house unless you have to. Every piece
      matters more to us now than it did before.\u201D"
    secondChoiceA: "\u201CI\u2019ll be careful.\u201D "
    secondChoiceB: "\u201CWe might not have a choice.\u201D "
    finalLine: "\u201CBe smart boy\u201D. They won\u2019t meet your eyes.\r"
  - firstLine: "\u201CYou\u2019ve heard it at night, haven\u2019t you? The sound
      that doesn\u2019t quite belong to the wind. We know you have.\u201D\r\n"
    firstChoiceA: "\u201CYeah\u2026 I heard it.\u201D "
    firstChoiceB: "\u201CI try not to listen.\u201D "
    secondLine: "\u201CDon\u2019t say its name out loud. Not in here. Not where it
      can hear us.\u201D\r\n"
    secondChoiceA: "\u201COkay.\u201D "
    secondChoiceB: "\u201CWhy not?\u201D "
    finalLine: "\u201CJust focus on the house\"... Dad keeps muttering \"the house\"
      over and over again. "
  - firstLine: "\u201CThe floorboards feel weak now. When we step, it doesn\u2019t
      sound like wood anymore. It sounds like somethings underneath it.\u201D\r\n"
    firstChoiceA: "\u201CLike it\u2019s cracking?\u201D "
    firstChoiceB: "\u201CWhat's under there?\u201D "
    secondLine: "\u201CIt\u2019s taking pieces, little by little. Things we don\u2019t
      notice until they\u2019re already gone.\u201D\r\n"
    secondChoiceA: "\u201CI know.\u201D "
    secondChoiceB: "\u201CWe can stop it.\u201D "
    finalLine: 'The words sink in the room.

'
  - firstLine: "\u201CI walked the hallway this morning, and it felt different. Like
      the space wasn\u2019t quite the same as yesterday.\u201D\r\n"
    firstChoiceA: "\u201CI felt that too.\u201D "
    firstChoiceB: "\u201CIt\u2019s just the winter.\u201D "
    secondLine: "\u201CWe can\u2019t lose the structure. Not now. Not when everything
      else is already slipping.\u201D\r\n"
    secondChoiceA: " \u201CWe\u2019ll last.\u201D "
    secondChoiceB: "\u201CThat\u2019s not comforting.\u201D "
    finalLine: "They almost laugh. \r\n"
  - firstLine: "\u201CIt used to be smaller.\u201D\r\n"
    firstChoiceA: "\u201CWhat did?\u201D "
    firstChoiceB: "\u201CIt\u2019s growing?\u201D "
    secondLine: "\u201CThat thing...we kept feeding it.\u201D\r\n"
    secondChoiceA: "\u201CThat\u2019s not what\u2019s happening.\u201D "
    secondChoiceB: " \u201CWe didn\u2019t have a choice.\u201D "
    finalLine: 'They look at the floor... I can tell mom is crying.

'
  - firstLine: "\u201CThere are parts of this house I don\u2019t recognize anymore.
      I walk through them and it feels like I\u2019m somewhere else.\u201D\r\n"
    firstChoiceA: "\u201CMe too.\u201D "
    firstChoiceB: "\u201CIt\u2019s still the same house.\u201D "
    secondLine: "\u201CIt\u2019s taking more than we thought it would. More than
      we planned for.\u201D\r\n"
    secondChoiceA: "\"We can stop it.\u201D "
    secondChoiceB: '"It''s almost over."'
    finalLine: "They don\u2019t correct you.\r\n"
  - firstLine: "\u201CIf we lose the house, there\u2019s nowhere left for us to go.
      You understand that now, don\u2019t you?\u201D\r\n"
    firstChoiceA: "\u201CI understand.\u201D "
    firstChoiceB: "\u201CI don\u2019t want to.\u201D "
    secondLine: "\u201CYou\u2019ve seen what happens when we lose too much. Things
      don\u2019t come back the same\u2026 if they come back at all.\u201D\r\n"
    secondChoiceA: "\u201CI\u2019ve seen it.\u201D "
    secondChoiceB: "\u201CI try not to think about it.\u201D "
    finalLine: "They look empty.\r"
  sisterMorningDialogues:
  - firstLine: "\u201CIt was really loud last night\u2026\u201D\r\n"
    firstChoiceA: "\u201CI heard it too.\u201D "
    firstChoiceB: "\u201CIt was just the wind.\u201D "
    secondLine: "\u201CIt didn\u2019t sound like wind.\u201D\r\n"
    secondChoiceA: "\u201CIt\u2019s okay.\u201D "
    secondChoiceB: "\u201CI know.\u201D "
    finalLine: 'She hugs her knees.

'
  - firstLine: "\u201CI had a bad dream.\u201D\r\n"
    firstChoiceA: "\u201CWhat was it?\u201D "
    firstChoiceB: "\u201CIt\u2019s just a dream.\u201D "
    secondLine: "\u201CSomething was eating...it sounded really gross. I tried to
      run but I couldn't.\u201D\r\n"
    secondChoiceA: "\u201CThat\u2019s normal. It was just a dream. I get them too.\u201D "
    secondChoiceB: " \u201CWhat was it eating?\u201D "
    finalLine: "She doesn\u2019t answer.\r\n"
  - firstLine: "\u201CIt sounded like chewing last night. Coming from the barn...like
      my dream..\u201D\r\n"
    firstChoiceA: "\u201CYou imagined it.\u201D "
    firstChoiceB: "\u201CI heard that too.\u201D "
    secondLine: "\u201CBut slower.\u201D\r\n"
    secondChoiceA: " \u201CYou\u2019re okay Jane.\u201D "
    secondChoiceB: "\u201CThat\u2019s weird.\u201D "
    finalLine: 'She looks out the window.

'
  - firstLine: "\u201CYou said something in your sleep. It sounded like a name\u2026
      Don. What does that mean?\u201D\r\n"
    firstChoiceA: "\u201CIt\u2019s nothing.\u201D "
    firstChoiceB: "\u201CIt\u2019s outside.\u201D "
    secondLine: "\u201CIs that what\u2019s been talking? Is that what I\u2019ve been
      hearing this whole time?\u201D\r\n"
    secondChoiceA: "\u201CIt\u2019s not real.\u201D "
    secondChoiceB: "\u201CMaybe.\u201D "
    finalLine: " \u201CIt didn\u2019t sound scary before\". She frowns.\n"
  - firstLine: "\u201CI think it likes us.\u201D"
    firstChoiceA: "\u201CWhy?\u201D "
    firstChoiceB: "\u201CThat\u2019s not good.\u201D "
    secondLine: "\u201CBecause we give it things. Mom says it's good to share\u201D\r\n"
    secondChoiceA: " \u201CThat\u2019s not what\u2019s happening.\u201D "
    secondChoiceB: " \u201CYeah...I think you're right Jane\u201D "
    finalLine: 'She shrugs.

'
  - firstLine: "\u201CIt\u2019s quieter now. I don\u2019t hear it chewing anymore.\"\r\n"
    firstChoiceA: "\u201CThat\u2019s good.\u201D"
    firstChoiceB: "\u201CThat\u2019s weird.\u201D "
    secondLine: "\u201CIt used to feel close, like it was right outside. Now it feels
      like it\u2019s somewhere else.\u201D\r\n"
    secondChoiceA: "\u201CThat\u2019s good.\u201D "
    secondChoiceB: "\u201CThat\u2019s not good.\u201D "
    finalLine: "\u201CWhere did it go?\u201D. She looks at you strangely.\n"
  - firstLine: "\u201CIt doesn\u2019t sound like a friend anymore. It used to feel
      softer, but now it just feels\u2026 wrong.\u201D\r\n"
    firstChoiceA: "\u201CIt never was.\u201D "
    firstChoiceB: "\u201CMaybe it still is, Jane.\u201D "
    secondLine: "\u201CSometimes it sounds like you. Not exactly, but close enough
      that it scares me.\u201D\r\n"
    secondChoiceA: " \u201CStop listening to Dad when he's drunk. Okay?.\u201D "
    secondChoiceB: "\u201CWhat do you mean?\u201D "
    finalLine: "\u201CI just...don\u2019t like it anymore\". She tilts her head.\n"
  - firstLine: "\u201CYou\u2019ve been acting different. You don\u2019t talk the
      same, and you don\u2019t look the same either.\u201D\r"
    firstChoiceA: "\u201CI\u2019m just tired.\u201D "
    firstChoiceB: "\u201CI feel it too.\u201D "
    secondLine: "\u201CIt\u2019s like you\u2019re not really here all the time. Like
      part of you is somewhere else.\u201D\r\n"
    secondChoiceA: "\u201CThat\u2019s not true.\u201D "
    secondChoiceB: "\u201CI'm trying really hard, Jane.\u201D"
    finalLine: "\u201CI don\u2019t like this\". She presses her stomach. A faint
      growl is heard.\n"
  - firstLine: "\u201CI don\u2019t want it to take anything else. Not the house,
      not our stuff\u2026 not us.\u201D"
    firstChoiceA: "\u201CIt won\u2019t.\u201D "
    firstChoiceB: "\u201CStop thinking about it.\u201D "
    secondLine: "\u201CCan you make it stop? Or is it just going to keep going forever?\u201D\r\n"
    secondChoiceA: "\u201CI\u2019ll try.\u201D "
    secondChoiceB: "\u201CI don\u2019t know.\u201D "
    finalLine: "\u201CPlease don\u2019t let it take me.\u201D\r\n"
  - firstLine: "\u201CYou\u2019re going to choose, aren\u2019t you? I can tell. You\u2019ve
      been thinking about it this whole time.\u201D\r\n"
    firstChoiceA: "\u201CI have to.\u201D "
    firstChoiceB: "\u201CI won\u2019t.\u201D "
    secondLine: "\u201CI don\u2019t want to disappear like everything else. I don\u2019t
      want to just be gone.\u201D\r\n"
    secondChoiceA: "\u201CYou won\u2019t.\u201D "
    secondChoiceB: "\u201CDon\u2019t say that\u2026\u201D "
    finalLine: " \u201CStay with me\". She just stares...she doesn't look like Janey
      anymore.\n"
  selfMorningDialogues:
  - firstLine: 'You look tired.

'
    firstChoiceA: "\u201CI\u2019m fine.\u201D "
    firstChoiceB: " \u201CI look awful.\u201D "
    secondLine: 'Your stomach aches.

'
    secondChoiceA: " \u201CIt\u2019s nothing.\u201D "
    secondChoiceB: "\u201CThat\u2019s new.\u201D "
    finalLine: 'You ignore it.

'
  - firstLine: ' Your mouth feels dry.

'
    firstChoiceA: " \u201CI need water.\u201D "
    firstChoiceB: "\u201CSomething\u2019s wrong.\u201D "
    secondLine: ' But not empty.

'
    secondChoiceA: " \u201CWhat?\u201D "
    secondChoiceB: " \u201CWhat do you mean?\u201D "
    finalLine: 'You swallow. It hurts.

'
  - firstLine: 'You feel something shift inside you.

'
    firstChoiceA: "\u201CNo I don\u2019t.\u201D "
    firstChoiceB: "\u201CI felt that.\u201D "
    secondLine: 'Like something turning.

'
    secondChoiceA: " \u201CStop.\u201D "
    secondChoiceB: "\u201CThat\u2019s not possible.\u201D "
    finalLine: 'You grip the sink.

'
  - firstLine: "You\u2019re starting to understand it. Not what it is, but how it
      works. The way things disappear, the way it takes."
    firstChoiceA: "\u201CThere's no logic to it.\u201D "
    firstChoiceB: " \u201CI don't wanna talk.\u201D "
    secondLine: "It\u2019s watching you.\r\n"
    secondChoiceA: "\u201CIt\u2019s not.\u201D "
    secondChoiceB: "\u201CI know.\u201D "
    finalLine: "You don\u2019t recognize your face.\r\n"
  - firstLine: "You feel lighter today. Not better, just\u2026 lighter. Like something
      is missing that used to be there."
    firstChoiceA: "\u201CI didn\u2019t do that.\u201D "
    firstChoiceB: " \u201CThat was me.\u201D "
    secondLine: "But at the same time, something else is there instead. Something
      you can\u2019t explain."
    secondChoiceA: " \u201CNo.\u201D "
    secondChoiceB: "\u201CLearning what?\u201D "
    finalLine: 'Your stomach twists.

'
  - firstLine: ' You feel full.

'
    firstChoiceA: "\u201CI haven\u2019t eaten.\u201D "
    firstChoiceB: "\u201CThat\u2019s wrong.\u201D "
    secondLine: "You don\u2019t remember being hungry."
    secondChoiceA: " \u201CStop.\u201D "
    secondChoiceB: "\u201CI was\u201D "
    finalLine: You gag slightly. Your teeth hurt.
  - firstLine: "Your voice sounds different when you speak. There\u2019s a slight
      echo to it, like it\u2019s coming from somewhere deeper."
    firstChoiceA: "\u201CI hear it.\u201D "
    firstChoiceB: " \u201CIt doesn\u2019t.\u201D "
    secondLine: "You don\u2019t feel as scared as you used to. That should bother
      you more than it does."
    secondChoiceA: "\u201CIt does.\u201D "
    secondChoiceB: "\u201CIt doesn\u2019t.\u201D "
    finalLine: "That\u2019s the problem...You step back fast.\n"
  - firstLine: 'You hear something inside you.

'
    firstChoiceA: "\u201CMy heartbeat.\u201D "
    firstChoiceB: "\u201CThat\u2019s not my heartbeat.\u201D "
    secondLine: It sounds like chewing.
    secondChoiceA: " \u201CStop thinking.\u201D "
    secondChoiceB: " \u201CNo\u2026\u201D "
    finalLine: 'You feel it moving

'
  - firstLine: You know what it wants now. Not just the words, but the meaning behind
      them. You understand the pattern.
    firstChoiceA: " \u201CThat\u2019s good.\u201D "
    firstChoiceB: "\u201CThat\u2019s wrong.\u201D "
    secondLine: "You know how to give it what it wants. You\u2019ve been doing it
      this whole time."
    secondChoiceA: "\u201CI have.\u201D "
    secondChoiceB: '"Stop..stop this please."'
    finalLine: "You\u2019re part of it now. Your reflection smiles.\n"
  - firstLine: "You understand completely now. The choices don\u2019t feel as hard
      anymore, because you know what they lead to."
    firstChoiceA: "\u201CI understand.\u201D "
    firstChoiceB: " \u201CI don't wanna talk.\u201D "
    secondLine: "It doesn\u2019t feel like something is being taken anymore. It feels
      like something is being chosen."
    secondChoiceA: "\u201CIt\u2019s not.\u201D "
    secondChoiceB: "\u201CI know.\u201D "
    finalLine: "And you\u2019re the one choosing."
  isMorningPhase: 0
