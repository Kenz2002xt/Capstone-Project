--- !u!114 &272921442
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 154367466}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Leather Chair
    requestTags:
    - Comfort
    - Escape
    - Silence
    consequenceLines:
    - "\u201CThere\u2019s nowhere to really sit anymore. The room feels harder, less
      comfortable. Like we lost the only place you could rest. We feel farther apart.\u201D"
    - "\u201CI didn\u2019t realize how much that spot mattered. Now the room feels
      empty in the wrong way. Like something important was taken out of it. We feel
      farther apart.\u201D"
    statTag: Family
    value: 14
    sacrificeWeight: 0
    descriptions:
    - Dad always sits here after dinner. It's good for him.
    - It creaks when someone leans back. I know who it is just by the sound.
    - 'The chair feels worn in, like it remembers all of us sitting here before things
      got quiet. '
