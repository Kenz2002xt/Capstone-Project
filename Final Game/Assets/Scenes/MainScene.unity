--- !u!114 &1041231474
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1041231473}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Guitar
    requestTags:
    - Noise
    - Distraction
    consequenceLines:
    - "\"The silence feels heavier now. There\u2019s nothing to fill it, nothing
      to break it up. Every sound feels sharper without it. I feel worse.\""
    - "\"I notice how quiet everything really is. It\u2019s not peaceful\u2026it\u2019s
      wrong. Like something is waiting in that silence. I feel worse.\""
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - 'I play this when it gets too quiet. Or too loud. '
    - 'The strings sound soft when I strum them slowly. '
    - "It fills the room so I don\u2019t have to think. "
