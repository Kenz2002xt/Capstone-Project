  m_Script: {fileID: 11500000, guid: 0624eb1fca3eb7d41b9f8fdabf721b74, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  narrativeUI: {fileID: 463752747}
  events:
  - description: "It started a few days ago. \r"
    resultHint: "The house is quieter than it should be, like something is listening.
      They told me what to do. Don takes what you give him. And if you don\u2019t
      give him something\u2026 he takes it anyway. I have to choose what matters...
      The house, the family, myself... I know I can\u2019t keep all of it...but I
      also can't let any of it get destroyed. \r"
    dayOneOnly: 1
    isPositive: 0
    affectedStat: 
    statChange: 0
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 0
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: Mother Cleans Out a Room.
    resultHint: "Your mother spent the morning clearing out things she said were
      \u201Cjust taking up space.\u201D By the time you noticed, several useful things
      were already gone...Three items have been remvoed.\r\n\r"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Family
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 3
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Something Went Missing Overnight.\r\r"
    resultHint: "You wake up and notice gaps where things used to be. Your memory
      isn't what it used to be. Did you misplace something?...Two items have been
      removed.\r\n\r"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Self
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 3
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Something Left at the Door.\r"
    resultHint: "There\u2019s a small bundle left outside the front door. Nobody\u2019s
      there when I look, but it wasn\u2019t there last night...There will be an extra
      option at sacrifice today. It should help the house hold a little longer...Don
      will accept it no matter what.\r"
    dayOneOnly: 0
    isPositive: 1
    affectedStat: Home
    statChange: 0
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 0
    bonusItem:
      itemName: Gift
      requestTags:
      - Warmth
      - Comfort
      - Protection
      - Noise
      - Distraction
      - Memory
      - Escape
      - Information
      - Silence
      - Hunger
      - Sight
      - Blood
      consequenceLines:
      - "\u201CWhoever left this knew what we needed. The house feels a little stronger.
        It won\u2019t give out just yet.\u201D"
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Old Family Item Found.\r"
    resultHint: "I find something tucked away that should\u2019ve been lost already.
      It's dusty but it feels like something meant to keep us together. A break from
      the constant sacrifices...Don will accept it no matter what.\r"
    dayOneOnly: 0
    isPositive: 1
    affectedStat: Family
    statChange: 0
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 0
    bonusItem:
      itemName: Family Ring
      requestTags:
      - Warmth
      - Comfort
      - Protection
      - Noise
      - Distraction
      - Memory
      - Escape
      - Information
      - Silence
      - Hunger
      - Sight
      - Blood
      consequenceLines:
      - "\"It used to belong to someone in the family. Giving it away for all of
        us makes it feel like we\u2019re not as far apart as we\u2019ve been.\""
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Thrown Into the Trash.\r"
    resultHint: Dad got rid of a few things without asking. He said they looked broken
      or useless, but you know better...Three items have been removed.
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Family
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 3
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Water Damage.\r"
    resultHint: "A leak from the roof spread farther than anyone realized. By the
      time it was found, several belongings were too soaked to keep...Two items have
      been removed\r\n\r\r"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Home
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 2
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Broken During the Night\r\r"
    resultHint: ' A few things were found snapped, cracked, or split open this morning.
      No one heard it happen. Must of been the rats Jane was talking about. Guess
      the traps didn''t work...Two items have been removed.'
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Home
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 2
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "A Small Good Moment.\r"
    resultHint: "For a second, we almost feel normal again. My Mom laughs, and it
      sounds real enough that I don\u2019t want to move. It helps to remember we\u2019re
      still here together. The family is stronger today.\r\n"
    dayOneOnly: 0
    isPositive: 1
    affectedStat: Family
    statChange: 10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 0
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Your Sister Took Something Apart.\r"
    resultHint: "Jane said she was just playing, but a few things ended up ruined
      before anyone stopped her. She didn\u2019t understand why everyone got so upset...Two
      items have been removed.\r\n"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Family
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 2
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: Coughing Blood.
    resultHint: "I woke up coughing and taste blood in the back of my throat. It
      takes a while for my hands to stop shaking. \r\n"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Self
    statChange: -10
    neededItemName: Pain Killers
    hasItemText: "I check the cabinet and the pain killer is still there. It\u2019s
      good I kept it. I think I\u2019ve saved myself today."
    missingItemText: 'I check the cabinet and the pain killers are gone. I can feel
      what it cost me. I feel worse today.

'
    randomItemsToRemove: 0
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "The Shadows Move Wrong.\r"
    resultHint: "The shadows in the corners don\u2019t stay where they should this
      morning. I keep looking back at them even when I know I shouldn\u2019t."
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Self
    statChange: -10
    neededItemName: Flashlight
    hasItemText: "I still have the flashlight. The beam cuts through the dark and
      makes the room feel real again. I think I\u2019m safer with it."
    missingItemText: "I reach for the flashlight and remember it\u2019s gone. The
      room feels deeper without it, like I\u2019ve lost one more way to protect myself.
      I feel worse today.\r\n"
    randomItemsToRemove: 0
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "A Clear Morning.\r"
    resultHint: ' For once, I wake up and everything feels quiet in the right way.
      My head feels lighter than it has in days. I feel a little more like myself.
      I''ll be okay today.'
    dayOneOnly: 0
    isPositive: 1
    affectedStat: Self
    statChange: 10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 0
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "Dad Locked Things Away.\r"
    resultHint: "Dad put some things somewhere \u201Csafe,\u201D but won\u2019t say
      where. For now, they may as well be gone. The paranoia is getting to him...Two
      items have been removed.\r\n"
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Family
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 2
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
  - description: "An Argument Ended Badly.\r"
    resultHint: "Voices got raised, something was knocked over, and a few things
      didn\u2019t survive it. No one wants to talk about what happened...Three items
      have been removed."
    dayOneOnly: 0
    isPositive: 0
    affectedStat: Family
    statChange: -10
    neededItemName: 
    hasItemText: 
    missingItemText: 
    randomItemsToRemove: 3
    bonusItem:
      itemName: 
      requestTags: []
      consequenceLines: []
      statTag: 
      value: 0
      sacrificeWeight: 0
      descriptions: []
