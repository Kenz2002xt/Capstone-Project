  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 02dc830dd6e0a194bbfe391c99606bdc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  item:
    itemName: Poster
    requestTags:
    - Distraction
    - Escape
    consequenceLines:
    - "\"There\u2019s nothing left on the wall to look at. The room feels dull and
      empty now. It\u2019s harder to pretend things are normal. I feel worse.\""
    - "\"I catch myself staring at the blank space. There\u2019s nowhere to escape
      to anymore, even for a second. I feel worse. \""
    statTag: Self
    value: 14
    sacrificeWeight: 0
    descriptions:
    - I stare at this a lot. I go somewhere else in my mind when I do.
    - "It\u2019s bright and colorful. It doesn\u2019t belong in this house anymore.
      But it's mine. "
